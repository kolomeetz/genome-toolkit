# ── Required ─────────────────────────────────────────────────────────────
# Path to your Obsidian genome vault
GENOME_VAULT_ROOT=~/genome-vault

# Path to genome.db SQLite database (usually inside the vault)
GENOME_DB_PATH=~/genome-vault/data/genome.db

# ── Optional ─────────────────────────────────────────────────────────────
# Data directory for users.db and cache
GENOME_DATA_DIR=./data

# Anthropic API key for AI chat features
# ANTHROPIC_API_KEY=sk-ant-...

# HuggingFace token for GWAS data downloads (higher rate limits)
# Get one at https://huggingface.co/settings/tokens
# HF_TOKEN=hf_...

# Groq API key for text-to-speech
# GROQ_API_KEY=gsk_...

# CORS origins (comma-separated, default: http://localhost:5173)
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000
